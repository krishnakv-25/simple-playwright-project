{
  "name": "simple-playwright-project",
  "version": "1.0.0",
  "description": "Senior SDET portfolio project — end-to-end, API, visual, and accessibility test automation built with Playwright + TypeScript",
  "private": true,
  "type": "module",
  "author": "Krishna (https://github.com/krishnakv-25)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/krishnakv-25/simple-playwright-project.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=chromium-ui --project=firefox-ui --project=webkit-ui",
    "test:api": "playwright test --project=api",
    "test:visual": "playwright test --project=visual",
    "test:a11y": "playwright test --project=accessibility",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui-mode": "playwright test --ui",
    "test:update-snapshots": "playwright test --project=visual --update-snapshots",
    "report": "playwright show-report",
    "report:allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "report:allure:open": "allure open ./allure-report",
    "codegen": "playwright codegen",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,yml}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "docker:build": "docker build -t playwright-sdet-portfolio .",
    "docker:run": "docker compose up --abort-on-container-exit --exit-code-from playwright"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.22.0",
    "@faker-js/faker": "^9.6.0",
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "typescript-eslint": "^8.26.0",
    "allure-commandline": "^2.32.0",
    "allure-playwright": "^3.2.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-playwright": "^2.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  }
}
